{% extends 'base.html.twig' %}

{% block title %}Inscription · Stickers Manager{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm overflow-hidden">
            <div class="sticker-hero text-center">
                <svg class="hero-illustration" width="220" height="96" viewBox="0 0 220 96" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <g transform="translate(36 58) rotate(-8)">
                        <rect x="-22" y="-22" width="44" height="44" fill="#37b24d" stroke="#fff" stroke-width="3"/>
                        <text x="0" y="6" font-size="17" text-anchor="middle" fill="#fff" font-family="'Press Start 2P', monospace">1</text>
                    </g>
                    <g transform="translate(184 58) rotate(8)">
                        <rect x="-22" y="-22" width="44" height="44" fill="#f59f00" stroke="#fff" stroke-width="3"/>
                        <text x="0" y="6" font-size="17" text-anchor="middle" fill="#fff" font-family="'Press Start 2P', monospace">2</text>
                    </g>
                    <circle cx="110" cy="46" r="22" fill="#fff" stroke="#14182b" stroke-width="3"/>
                    <polygon points="110,37 118.6,43.2 115.3,53.3 104.7,53.3 101.4,43.2" fill="#14182b"/>
                    <g stroke="#14182b" stroke-width="2">
                        <line x1="110" y1="37" x2="110" y2="24"/>
                        <line x1="118.6" y1="43.2" x2="130.9" y2="39.2"/>
                        <line x1="115.3" y1="53.3" x2="122.9" y2="63.8"/>
                        <line x1="104.7" y1="53.3" x2="97.1" y2="63.8"/>
                        <line x1="101.4" y1="43.2" x2="89.1" y2="39.2"/>
                    </g>
                </svg>
                <h1 class="h4 mt-2 mb-0">Créer un compte</h1>
            </div>
            <div class="card-body p-4">
                {{ form_start(registrationForm) }}
                    <div class="mb-3">
                        {{ form_label(registrationForm.email) }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(registrationForm.displayName) }}
                        {{ form_widget(registrationForm.displayName, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.displayName) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(registrationForm.country) }}
                        {{ form_widget(registrationForm.country, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(registrationForm.country) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword.first) }}
                        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.plainPassword.first) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword.second) }}
                        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <button class="btn btn-success w-100" type="submit">
                        <i class="bi bi-person-plus"></i> S'inscrire
                    </button>
                {{ form_end(registrationForm) }}

                <p class="text-center mt-3 mb-0">
                    Déjà inscrit ? <a href="{{ path('app_login') }}">Connecte-toi</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
