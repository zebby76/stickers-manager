{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-8">
            {{ form_label(form.name) }}
            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.name) }}
        </div>
        <div class="col-md-4">
            {{ form_label(form.year) }}
            {{ form_widget(form.year, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.publisher) }}
            {{ form_widget(form.publisher, {'attr': {'class': 'form-control'}}) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.stickersPerPack) }}
            {{ form_widget(form.stickersPerPack, {'attr': {'class': 'form-control'}}) }}
            <div class="form-text">{{ form_help(form.stickersPerPack) }}</div>
        </div>
        <div class="col-12">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
        <a href="{{ path('app_album_index') }}" class="btn btn-link">Annuler</a>
    </div>
{{ form_end(form) }}
