{% extends 'base.html.twig' %}

{% block title %}Modifier {{ album.name }} · Stickers Manager{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="h3 mb-4">Modifier l'album</h1>
        <div class="card shadow-sm"><div class="card-body">
            {{ include('album/_form.html.twig') }}
        </div></div>

        <form method="post" action="{{ path('app_album_delete', {slug: album.slug}) }}" class="mt-3"
              onsubmit="return confirm('Supprimer cet album et toutes ses vignettes ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete-album-' ~ album.id) }}">
            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Supprimer l'album</button>
        </form>
    </div>
</div>
{% endblock %}
