{% extends 'base.html.twig' %}

{% block title %}Échanges · Stickers Manager{% endblock %}

{% macro status_badge(status) %}
    {% set map = {'pending': 'secondary', 'accepted': 'info', 'declined': 'danger', 'cancelled': 'dark', 'completed': 'success'} %}
    <span class="badge text-bg-{{ map[status.value] }}">{{ status.label }}</span>
{% endmacro %}

{% block body %}
{% import _self as ui %}
<h1 class="h3 mb-4"><i class="bi bi-arrow-left-right"></i> Échanges</h1>

<h2 class="h5 mb-3">Collectionneurs compatibles</h2>
{% if matches is empty %}
    <div class="alert alert-info">Aucune correspondance pour l'instant. Ajoute des doublons et suis des albums pour trouver des partenaires d'échange.</div>
{% else %}
    <div class="row g-3 mb-5">
        {% for match in matches %}
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <h3 class="h6 mb-0"><i class="bi bi-person-circle"></i> {{ match.other.displayName }}</h3>
                            {% if match.isMutual %}<span class="badge text-bg-success">Match mutuel</span>{% endif %}
                        </div>
                        {{ include('_reputation.html.twig', {reputation: reputations[match.other.id]}) }}
                        <div class="d-flex gap-3 my-2">
                            <span class="text-success"><i class="bi bi-arrow-up-right"></i> Je peux donner : <strong>{{ match.giveCount }}</strong></span>
                        </div>
                        <div class="d-flex gap-3 mb-2">
                            <span class="text-primary"><i class="bi bi-arrow-down-left"></i> Je peux recevoir : <strong>{{ match.receiveCount }}</strong></span>
                        </div>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="{{ path('app_trade_with', {id: match.other.id}) }}" class="btn btn-sm btn-primary w-100">Proposer un échange</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

<div class="row">
    <div class="col-lg-6 mb-4">
        <h2 class="h5 mb-3">Propositions reçues</h2>
        {% if incoming is empty %}
            <p class="text-muted">Aucune proposition reçue.</p>
        {% else %}
            <div class="list-group">
                {% for p in incoming %}
                    <a href="{{ path('app_trade_show', {id: p.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>De <strong>{{ p.fromUser.displayName }}</strong> · {{ p.items|length }} vignette(s)</span>
                        {{ ui.status_badge(p.status) }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
    <div class="col-lg-6 mb-4">
        <h2 class="h5 mb-3">Propositions envoyées</h2>
        {% if outgoing is empty %}
            <p class="text-muted">Aucune proposition envoyée.</p>
        {% else %}
            <div class="list-group">
                {% for p in outgoing %}
                    <a href="{{ path('app_trade_show', {id: p.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>À <strong>{{ p.toUser.displayName }}</strong> · {{ p.items|length }} vignette(s)</span>
                        {{ ui.status_badge(p.status) }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
