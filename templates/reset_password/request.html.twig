{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié · Stickers Manager{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm overflow-hidden">
            <div class="sticker-hero text-center">
                <h1 class="h4 mb-0"><i class="bi bi-key"></i> Mot de passe oublié</h1>
            </div>
            <div class="card-body p-4">
                <p>Saisis ton adresse e-mail : si un compte existe, nous t’enverrons un lien pour réinitialiser ton mot de passe.</p>

                {% form_theme requestForm 'bootstrap_5_layout.html.twig' %}
                {{ form_start(requestForm) }}
                    {{ form_row(requestForm.email) }}
                    <button class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-envelope"></i> Envoyer le lien
                    </button>
                {{ form_end(requestForm) }}

                <p class="text-center mt-3 mb-0">
                    <a href="{{ path('app_login') }}">Retour à la connexion</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
