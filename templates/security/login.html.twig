{% extends 'base.html.twig' %}

{% block title %}Connexion · Stickers Manager{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm overflow-hidden">
            <div class="sticker-hero text-center">
                <svg class="hero-illustration" width="220" height="96" viewBox="0 0 220 96" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <g transform="translate(36 58) rotate(-8)">
                        <rect x="-22" y="-22" width="44" height="44" fill="#37b24d" stroke="#fff" stroke-width="3"/>
                        <text x="0" y="6" font-size="17" text-anchor="middle" fill="#fff" font-family="'Press Start 2P', monospace">1</text>
                    </g>
                    <g transform="translate(184 58) rotate(8)">
                        <rect x="-22" y="-22" width="44" height="44" fill="#f59f00" stroke="#fff" stroke-width="3"/>
                        <text x="0" y="6" font-size="17" text-anchor="middle" fill="#fff" font-family="'Press Start 2P', monospace">2</text>
                    </g>
                    <circle cx="110" cy="46" r="22" fill="#fff" stroke="#14182b" stroke-width="3"/>
                    <polygon points="110,37 118.6,43.2 115.3,53.3 104.7,53.3 101.4,43.2" fill="#14182b"/>
                    <g stroke="#14182b" stroke-width="2">
                        <line x1="110" y1="37" x2="110" y2="24"/>
                        <line x1="118.6" y1="43.2" x2="130.9" y2="39.2"/>
                        <line x1="115.3" y1="53.3" x2="122.9" y2="63.8"/>
                        <line x1="104.7" y1="53.3" x2="97.1" y2="63.8"/>
                        <line x1="101.4" y1="43.2" x2="89.1" y2="39.2"/>
                    </g>
                </svg>
                <h1 class="h4 mt-2 mb-0"><span class="brand-badge">Stickers</span> Manager</h1>
            </div>
            <div class="card-body p-4">
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label for="username" class="form-label">Adresse e-mail</label>
                        <input type="email" name="_username" id="username" value="{{ last_username }}"
                               class="form-control" autocomplete="email" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Mot de passe</label>
                        <input type="password" name="_password" id="password"
                               class="form-control" autocomplete="current-password" required>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="_remember_me" id="remember_me" checked>
                        <label class="form-check-label" for="remember_me">Se souvenir de moi</label>
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                           value="{{ csrf_token('authenticate') }}">

                    <button class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-box-arrow-in-right"></i> Se connecter
                    </button>
                </form>

                <p class="text-center mt-3 mb-0">
                    <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié&nbsp;?</a>
                </p>

                {% if google_sso_enabled %}
                    <div class="text-center text-muted my-3">— ou —</div>
                    <a href="{{ path('connect_google_start') }}" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-google"></i> Se connecter avec Google
                    </a>
                {% endif %}

                <p class="text-center mt-3 mb-0">
                    Pas encore de compte ? <a href="{{ path('app_register') }}">Inscris-toi</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
