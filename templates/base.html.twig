<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Stickers Manager{% endblock %}</title>
        {{ pwa() }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><circle cx=%2216%22 cy=%2216%22 r=%2214%22 fill=%22%23ffffff%22 stroke=%22%2314182b%22 stroke-width=%222%22/><polygon points=%2216,9 22,13.4 19.7,20.5 12.3,20.5 10,13.4%22 fill=%22%2314182b%22/></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {# Loaded once in <head> (with defer) so Turbo doesn't re-run it on each visit
       and double-register Bootstrap's dropdown/collapse click handlers. #}
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/flag-icons@7.5.0/css/flag-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand: #2f9e44;          /* pitch green (identity) */
            --brand-2: #2b8a3e;
            --brand-700: #1d8a5f;
            --brand-50: #eef7f1;       /* light tint */
            --accent: #ba7517;         /* desaturated amber */
            --gold: #ba7517;
            --amber-bg: #fac775; --amber-edge: #ba7517; --amber-ink: #633806;
            --mint-bg: #9fe1cb;  --mint-edge: #1d9e75;  --mint-ink: #085041;
            --red: #c0392b;
            --sky: #4dabf7;
            --ok: #2f9e44;
            --ink: #1b2235;            /* text & header */
            --line: #c3d2dc;           /* cool grey-blue borders */
            --muted: #6b7384;
            --bg: #dceaf2;             /* powder-blue field */
            --surface: #ffffff;
            --grad: linear-gradient(180deg, #37b24d 0%, #2f9e44 100%);
            --radius: 8px; --radius-sm: 6px;
            --shadow: 0 1px 2px rgba(27, 34, 53, .07), 0 4px 14px rgba(27, 34, 53, .05);
            --shadow-sm: 0 1px 2px rgba(27, 34, 53, .09);
            --font-pixel: 'Press Start 2P', system-ui, monospace;
            --font-body: 'VT323', ui-monospace, "Courier New", monospace;

            --bs-body-font-family: var(--font-body);
            --bs-body-color: var(--ink);
            --bs-body-bg: var(--bg);
            --bs-border-color: var(--line);
            --bs-border-width: 1px;
            --bs-border-radius: var(--radius); --bs-border-radius-sm: var(--radius-sm);
            --bs-border-radius-lg: 10px; --bs-border-radius-xl: 12px; --bs-border-radius-pill: 50rem;
            --bs-primary: #2f9e44;
            --bs-primary-rgb: 47, 158, 68;
            --bs-link-color: #1d8a5f;
            --bs-link-color-rgb: 29, 138, 95;
            --bs-link-hover-color: #14182b;
            --bs-link-hover-color-rgb: 20, 24, 43;
        }

        /* Refined: a single fine, cool dot grid on the powder-blue field */
        body {
            background:
                radial-gradient(circle at 1px 1px, rgba(27, 34, 53, .045) 1px, transparent 0) 0 0 / 22px 22px,
                var(--bg);
            background-attachment: fixed;
            color: var(--ink);
            font-size: 1.16rem; line-height: 1.4;
        }
        ::selection { background: rgba(47, 158, 68, .30); }
        img { image-rendering: pixelated; }

        h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6, .navbar-brand {
            font-family: var(--font-pixel); line-height: 1.5; letter-spacing: 0;
        }
        h1, .h1 { font-size: 1.3rem; }
        h2, .h2 { font-size: 1.05rem; }
        h3, .h3 { font-size: .92rem; }
        h4, .h4 { font-size: .82rem; }
        h5, .h5, h6, .h6 { font-size: .72rem; }
        .display-6 { font-family: var(--font-pixel); font-size: 1.25rem; }
        .small, small { font-size: .78em; }
        .text-gradient {
            background: linear-gradient(90deg, #2f9e44, #f59f00); -webkit-background-clip: text;
            background-clip: text; -webkit-text-fill-color: transparent; color: transparent;
        }

        /* —— Navbar (arcade scoreboard, sticky) —————————————————————— */
        .navbar-app {
            background: var(--ink);
            border-bottom: 1px solid rgba(255, 255, 255, .08);
            box-shadow: 0 1px 3px rgba(27, 34, 53, .12);
            position: sticky; top: 0; z-index: 1030;
        }
        .navbar-app .navbar-brand { font-size: .95rem; }
        .brand-badge {
            display: inline-block; color: #46d39a; font-style: normal;
        }
        .navbar-app .nav-link { font-family: var(--font-body); font-size: 1.2rem; border-radius: 0; padding-inline: .8rem; border-bottom: 2px solid transparent; color: rgba(255, 255, 255, .72); }
        .navbar-app .nav-link:hover, .navbar-app .nav-link:focus { background: transparent; color: #fff; }
        .navbar-app .nav-link.active { color: #fff; border-bottom-color: var(--mint-bg); }
        .navbar-app .dropdown-menu { border: 1px solid var(--line); border-radius: var(--radius-sm); box-shadow: var(--shadow); }
        .navbar-app .dropdown-item { font-family: var(--font-body); font-size: 1.15rem; padding: .4rem 1rem; }

        /* —— Sticker hero (holds a pixel SVG illustration) ——————————— */
        .sticker-hero {
            position: relative; overflow: hidden; color: #fff;
            background: var(--brand); border-bottom: 1px solid rgba(0, 0, 0, .12);
            padding: 1.6rem 1rem 1.3rem;
        }
        .sticker-hero > * { position: relative; z-index: 1; }
        .sticker-hero::before {
            content: ""; position: absolute; inset: 0;
            background: repeating-conic-gradient(rgba(255, 255, 255, .07) 0% 25%, transparent 0% 50%) 0 0 / 24px 24px;
        }
        .hero-illustration { image-rendering: pixelated; filter: drop-shadow(3px 3px 0 rgba(0, 0, 0, .3)); }

        /* —— Cards / surfaces ———————————————————————————————————————— */
        .card {
            border: 1px solid var(--line); border-radius: var(--radius);
            background: var(--surface); box-shadow: var(--shadow);
        }
        .card-header, .card-footer { background: transparent; border-color: var(--line); }
        .shadow-sm { box-shadow: var(--shadow-sm) !important; }

        /* —— Buttons (fine, clean hover) —————————————————————————————— */
        .btn {
            font-family: var(--font-pixel); font-size: .64rem; border-radius: var(--radius-sm);
            border: 1px solid var(--line); box-shadow: none;
            padding: .55rem .85rem; transition: filter .12s, box-shadow .12s, transform .06s;
        }
        .btn-sm { font-size: .56rem; padding: .4rem .65rem; }
        .btn:hover { transform: none; box-shadow: var(--shadow-sm); filter: brightness(.98); }
        .btn:active { transform: scale(.985); box-shadow: none; }
        .btn-primary { --bs-btn-bg: #2f9e44; --bs-btn-border-color: #2b8a3e; --bs-btn-hover-bg: #37b24d; --bs-btn-hover-border-color: #2f9e44; --bs-btn-active-bg: #237032; --bs-btn-color: #fff; --bs-btn-hover-color: #fff; }
        .btn-outline-primary { --bs-btn-color: #1d8a5f; --bs-btn-border-color: #9fcab8; --bs-btn-hover-bg: #2f9e44; --bs-btn-hover-border-color: #2f9e44; --bs-btn-hover-color: #fff; --bs-btn-active-bg: #237032; }
        .btn-success { --bs-btn-bg: #2f9e44; --bs-btn-border-color: #2b8a3e; --bs-btn-hover-bg: #37b24d; --bs-btn-hover-border-color: #2f9e44; --bs-btn-color: #fff; }
        .btn-amber { --bs-btn-bg: var(--amber-bg); --bs-btn-border-color: var(--amber-edge); --bs-btn-color: var(--amber-ink); --bs-btn-hover-bg: #f7bd5f; --bs-btn-hover-border-color: var(--amber-edge); --bs-btn-hover-color: var(--amber-ink); }
        .btn-mint { --bs-btn-bg: var(--mint-bg); --bs-btn-border-color: var(--mint-edge); --bs-btn-color: var(--mint-ink); --bs-btn-hover-bg: #8ad8bd; --bs-btn-hover-border-color: var(--mint-edge); --bs-btn-hover-color: var(--mint-ink); }
        .btn-link { font-family: var(--font-body); font-size: 1.15rem; border: 0; box-shadow: none; }
        .btn-link:hover, .btn-link:active { transform: none; box-shadow: none; }

        /* —— Forms ——————————————————————————————————————————————————— */
        .form-control, .form-select {
            border-radius: var(--radius-sm); border: 1px solid var(--line); background: #fff;
            font-family: var(--font-body); font-size: 1.15rem; padding: .45rem .7rem;
        }
        .form-control:focus, .form-select:focus { border-color: #2f9e44; box-shadow: 0 0 0 3px rgba(47, 158, 68, .18); }
        .form-label { font-family: var(--font-pixel); font-size: .62rem; }

        /* —— Progress ———————————————————————————————————————————————— */
        .progress { border-radius: 50rem; border: 1px solid var(--line); background: #eef3f7; height: 1.35rem; }
        .progress-bar { background: var(--brand); color: #fff; font-family: var(--font-body); }
        .progress-bar.bg-success { background: var(--brand) !important; }

        /* —— Badges / lists / accordion / tables / alerts ———————————— */
        .badge { border-radius: 5px; font-family: var(--font-body); font-weight: 400; font-size: .95rem; padding: .32em .6em; border: 1px solid rgba(27, 34, 53, .12); }
        .list-group-item { border-color: var(--line); }
        .list-group-item-action:hover { background: var(--brand-50); }
        .accordion { --bs-accordion-border-radius: var(--radius-sm); --bs-accordion-border-color: var(--line); --bs-accordion-active-bg: var(--brand-50); --bs-accordion-active-color: var(--brand-700); }
        .accordion-item { border: 1px solid var(--line); border-radius: var(--radius-sm) !important; }
        .accordion-button { font-family: var(--font-pixel); font-size: .72rem; }
        .alert { border: 1px solid var(--line); border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); }
        .table { --bs-table-hover-bg: var(--brand-50); }
        .badge-amber { background: var(--amber-bg); color: var(--amber-ink); border-color: var(--amber-edge); }
        .badge-mint  { background: var(--mint-bg);  color: var(--mint-ink);  border-color: var(--mint-edge); }

        /* —— Auto-fit tile grid + number chips (collection / duplicates views) —— */
        .tile-grid { display: grid; gap: 8px; grid-template-columns: repeat(auto-fit, minmax(165px, 1fr)); }
        .tile { background: #fff; border: 1px solid var(--line); border-radius: var(--radius-sm); padding: .5rem .6rem; }
        .tile-h { font-family: var(--font-pixel); font-size: .52rem; line-height: 1.5; color: var(--ink); margin-bottom: .45rem; display: flex; align-items: center; gap: .3rem; }
        .tile-h .count { margin-left: auto; color: var(--muted); }
        .num-chips { display: flex; flex-wrap: wrap; gap: 4px; }
        .num-chip { font-family: var(--font-body); font-size: .95rem; line-height: 1; padding: .2rem .42rem; border-radius: 5px; border: 1px solid var(--line); background: #f6f9fb; color: var(--ink); }
        .num-chip.dupe { background: var(--amber-bg); border-color: var(--amber-edge); color: var(--amber-ink); }
        .num-chip.miss { background: #fff; border-style: dashed; color: #7c8499; }
        /* Full-width action (body-mono) for the cards on the duplicates view */
        .cell-action { display: block; width: 100%; text-align: center; font-family: var(--font-body); font-size: 1.05rem; line-height: 1; padding: .42rem .5rem; border-radius: var(--radius-sm); border: 1px solid var(--line); background: #f6f9fb; color: var(--ink); transition: filter .12s; }
        a.cell-action:hover { filter: brightness(.97); }
        .cell-action.amber { background: var(--amber-bg); border-color: var(--amber-edge); color: var(--amber-ink); }
        .cell-action.mint  { background: var(--mint-bg);  border-color: var(--mint-edge);  color: var(--mint-ink); }
        .cell-code { font-family: var(--font-body); font-size: 1.15rem; font-weight: 500; color: var(--ink); }

        /* —— Sticker checklist (pixel die-cut) ——————————————————————— */
        .sticker-cell {
            border-radius: var(--radius-sm); border: 1px solid var(--line);
            box-shadow: var(--shadow-sm);
            transition: transform .08s, box-shadow .12s, filter .12s;
        }
        .sticker-cell:hover { transform: translateY(-1px); box-shadow: var(--shadow); }
        .owned { background: var(--mint-bg); color: var(--mint-ink); border-color: var(--mint-edge); }
        .missing { background: #fff; color: #9aa1b8; border-style: dashed !important; }
        .duplicate { box-shadow: var(--shadow-sm); border-color: var(--amber-edge); background: var(--amber-bg); }
        .rarity-shiny { background: linear-gradient(135deg, #fff3b0, #ffd0f0, #c7e0ff, #c9fff0); background-size: 220% 220%; animation: shimmer 6s ease-in-out infinite; }
        @keyframes shimmer { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }

        /* Click-to-collect cells */
        .sticker-clickable { cursor: pointer; user-select: none; -webkit-user-select: none; }
        .sticker-clickable:active { transform: scale(.95); }
        .sticker-counter {
            position: absolute; top: -8px; right: -8px; z-index: 2; min-width: 1.6em;
            border: 1px solid var(--ink) !important; border-radius: 50rem !important;
            box-shadow: var(--shadow-sm); animation: popIn .18s steps(3);
        }
        .sticker-counter.text-bg-success { background: var(--brand) !important; }
        /* Decrement button — works on touch (no right-click on mobile) */
        .sticker-dec {
            position: absolute; top: -8px; left: -8px; z-index: 3;
            min-width: 1.9em; height: 1.9em; padding: 0; line-height: 1;
            display: inline-flex; align-items: center; justify-content: center;
            border: 1px solid #a5342a; border-radius: 50rem; background: var(--red);
            color: #fff; font-family: var(--font-pixel); font-size: .62rem;
            box-shadow: var(--shadow-sm); cursor: pointer;
        }
        .sticker-dec:hover { background: #c92a2a; }
        .sticker-dec:active { transform: scale(.88); box-shadow: 0 0 0 rgba(20, 24, 43, .4); }
        .sticker-cell.pulse-add { animation: pulseAdd .2s steps(2); }
        .sticker-cell.pulse-remove { animation: pulseRemove .2s steps(2); }
        @keyframes popIn { 0% { transform: scale(.3); opacity: 0; } 60% { transform: scale(1.18); } 100% { transform: scale(1); opacity: 1; } }
        @keyframes pulseAdd { 0% { transform: scale(1); } 45% { transform: scale(1.12); } 100% { transform: scale(1); } }
        @keyframes pulseRemove { 0% { transform: scale(1); } 45% { transform: scale(.9); } 100% { transform: scale(1); } }

        /* —— Country flags (flag-icons) ——————————————————————————————— */
        .fi { border-radius: 2px; box-shadow: 0 0 0 1px var(--line); vertical-align: -2px; }
        .fi.flag-lg { width: 1.7em; line-height: 1.28em; }

        /* —— Compact filter toolbar + brand logo ————————————————————— */
        .filter-toolbar .btn {
            font-family: var(--font-body); font-size: 1rem; line-height: 1;
            padding: .28rem .6rem; border-width: 2px; box-shadow: none;
        }
        .filter-toolbar .btn:hover, .filter-toolbar .btn:active { transform: none; box-shadow: none; }
        .brand-logo { display: inline-block; vertical-align: -7px; image-rendering: pixelated; }

        /* —— Collector avatars (DiceBear pixel-art) ——————————————————— */
        .avatar { border-radius: var(--radius-sm); background: #fff; border: 1px solid var(--line); box-shadow: var(--shadow-sm); vertical-align: middle; image-rendering: pixelated; }
        .avatar-lg { width: 72px; height: 72px; border-width: 1px; box-shadow: var(--shadow); }

        /* —— Footer (version scoreboard) ————————————————————————————— */
        .app-footer {
            margin-top: auto; padding: 1rem; color: var(--muted);
            font-family: var(--font-body); font-size: 1rem;
            border-top: 1px solid var(--line);
        }
        .app-footer .app-version {
            font-family: var(--font-pixel); font-size: .58rem; color: var(--brand-700);
            border: 1px solid var(--line); border-radius: 5px; background: #fff; padding: .14rem .45rem;
            box-shadow: var(--shadow-sm); margin-left: .35rem;
        }
        body { display: flex; flex-direction: column; min-height: 100vh; }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{{ importmap('app') }}{% endblock %}
</head>
<body>
{% if app.user %}
    <nav class="navbar navbar-expand-lg navbar-dark navbar-app mb-4">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_dashboard') }}">
                <svg class="brand-logo" width="30" height="30" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="16" cy="16" r="14" fill="#fff" stroke="#14182b" stroke-width="2"/>
                    <polygon points="16,10 21.4,13.9 19.3,20.3 12.7,20.3 10.6,13.9" fill="#14182b"/>
                    <g stroke="#14182b" stroke-width="1.5">
                        <line x1="16" y1="10" x2="16" y2="2.5"/>
                        <line x1="21.4" y1="13.9" x2="29.2" y2="11.7"/>
                        <line x1="19.3" y1="20.3" x2="23.8" y2="26.8"/>
                        <line x1="12.7" y1="20.3" x2="8.2" y2="26.8"/>
                        <line x1="10.6" y1="13.9" x2="2.8" y2="11.7"/>
                    </g>
                </svg>
                <span class="brand-badge">Stickers</span> <span>Manager</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                {% set route = app.request.attributes.get('_route') %}
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link {{ route == 'app_dashboard' ? 'active' }}" href="{{ path('app_dashboard') }}"><i class="bi bi-speedometer2"></i> Tableau de bord</a></li>
                    <li class="nav-item"><a class="nav-link {{ route starts with 'app_album' ? 'active' }}" href="{{ path('app_album_index') }}"><i class="bi bi-collection"></i> Albums</a></li>
                    <li class="nav-item"><a class="nav-link {{ route == 'app_duplicates' ? 'active' }}" href="{{ path('app_duplicates') }}"><i class="bi bi-stack"></i> Mes doublons</a></li>
                    <li class="nav-item"><a class="nav-link {{ route starts with 'app_trade' ? 'active' }}" href="{{ path('app_trade_index') }}">
                        <i class="bi bi-arrow-left-right"></i> Échanges
                        {% set pending = pending_trades_count() %}
                        {% if pending > 0 %}<span class="badge text-bg-danger">{{ pending }}</span>{% endif %}
                    </a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                            <img src="{{ avatar_url(app.user.email) }}" alt="" width="30" height="30" class="avatar">
                            {{ app.user.displayName }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="bi bi-person"></i> Mon profil</a></li>
                            {% if is_granted('ROLE_ADMIN') %}
                                <li><a class="dropdown-item" href="{{ path('app_admin_users') }}"><i class="bi bi-people"></i> Utilisateurs
                                    {% set pend = pending_users_count() %}
                                    {% if pend > 0 %}<span class="badge text-bg-danger">{{ pend }}</span>{% endif %}
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_admin_trades') }}"><i class="bi bi-arrow-left-right"></i> Échanges (admin)</a></li>
                            {% endif %}
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i> Déconnexion</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
{% endif %}

<main class="container pb-5">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="app-footer text-center">
    <span class="brand-badge">Stickers</span> Manager{% if app_version %} <span class="app-version">v{{ app_version }}</span>{% endif %}
</footer>

</body>
</html>
