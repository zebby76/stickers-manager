{% extends 'base.html.twig' %}

{% block title %}E-mail envoyé · Stickers Manager{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm overflow-hidden">
            <div class="sticker-hero text-center">
                <h1 class="h4 mb-0"><i class="bi bi-envelope-check"></i> Vérifie tes e-mails</h1>
            </div>
            <div class="card-body p-4">
                <p>
                    Si un compte correspond à cette adresse, un e-mail contenant un lien de
                    réinitialisation vient d’être envoyé. Ce lien expirera dans
                    {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                </p>
                <p class="text-muted small mb-0">Pense à vérifier ton dossier spam si tu ne le vois pas.</p>

                <p class="text-center mt-3 mb-0">
                    <a href="{{ path('app_login') }}">Retour à la connexion</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
