{% extends 'base.html.twig' %}

{% block title %}Collection de {{ owner.displayName }} · Stickers Manager{% endblock %}

{% block body %}
<div class="text-center mb-4">
    <img src="{{ avatar_url(owner.email) }}" alt="" width="72" height="72" class="avatar avatar-lg mb-2">
    <h1 class="h3">
        {% if owner.country %}<span class="fi fi-{{ owner.country|lower }} me-2"></span>{% endif %}
        Collection de {{ owner.displayName }}
    </h1>
    <p class="text-muted mb-2">Vignettes <strong>à échanger</strong> (doublons) et <strong>manquantes</strong> — liste publique.</p>
    {{ include('_reputation.html.twig', {reputation: reputation}) }}
    {% if badges is not empty %}
        <div class="d-flex justify-content-center">
            {{ include('_badges.html.twig', {badges: badges, show_locked: false}) }}
        </div>
    {% endif %}
    {% if albums is not empty %}
        <div class="mt-3">
            <a href="{{ path('app_trade_with', {id: owner.id}) }}" class="btn btn-primary">
                <i class="bi bi-arrow-left-right"></i> Propose-moi un échange
            </a>
            <p class="text-muted small mt-1 mb-0">Connecte-toi pour voir ce qu'on peut s'échanger — la proposition est pré-remplie.</p>
        </div>
    {% endif %}
</div>

{% if albums is empty %}
    <div class="alert alert-info text-center">Aucun album suivi pour l'instant.</div>
{% endif %}

{% for a in albums %}
    <div class="card shadow-sm mb-4"><div class="card-body">
        <h2 class="h5 mb-3">{{ a.album.name }}{% if a.album.year %} <span class="text-muted fw-normal">({{ a.album.year }})</span>{% endif %}</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <h3 class="h6 mb-2"><i class="bi bi-stack"></i> Doublons à échanger
                    <span class="badge badge-amber">{{ a.duplicatesCount }}</span></h3>
                {% if a.duplicates is empty %}
                    <p class="text-muted small mb-0">Aucun doublon.</p>
                {% else %}
                    <div class="tile-grid">
                        {% for team, items in a.duplicates %}
                            {% set cc = country_code(team) %}
                            <div class="tile">
                                <div class="tile-h">{% if cc %}<span class="fi fi-{{ cc }}"></span>{% endif %}<span>{{ team }}</span><span class="count">{{ items|length }}</span></div>
                                <div class="num-chips">
                                    {% for it in items %}<span class="num-chip dupe">{{ it.sticker.number }}{% if it.spare > 1 %} ×{{ it.spare }}{% endif %}</span>{% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <div class="col-md-6">
                <h3 class="h6 mb-2"><i class="bi bi-search"></i> Manquantes
                    <span class="badge text-bg-danger">{{ a.missingCount }}</span></h3>
                {% if a.missing is empty %}
                    <p class="text-success small mb-0">Album complet ! 🎉</p>
                {% else %}
                    <div class="tile-grid">
                        {% for team, stickers in a.missing %}
                            {% set cc = country_code(team) %}
                            <div class="tile">
                                <div class="tile-h">{% if cc %}<span class="fi fi-{{ cc }}"></span>{% endif %}<span>{{ team }}</span><span class="count">{{ stickers|length }}</span></div>
                                <div class="num-chips">
                                    {% for s in stickers %}<span class="num-chip miss">{{ s.number }}</span>{% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div></div>
{% endfor %}

<p class="text-center text-muted small mt-4">⚽ Propulsé par Stickers Manager</p>
{% endblock %}
