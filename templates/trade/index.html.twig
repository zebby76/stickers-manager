{% extends 'base.html.twig' %}

{% block title %}Échanges · Stickers Manager{% endblock %}

{% block body %}
<h1 class="h3 mb-4"><i class="bi bi-arrow-left-right"></i> Échanges</h1>

<h2 class="h5 mb-3">Collectionneurs compatibles</h2>
{% if matches is empty %}
    <div class="alert alert-info">Aucune correspondance pour l'instant. Ajoute des doublons et suis des albums pour trouver des partenaires d'échange.</div>
{% else %}
    <div class="row g-3 mb-5">
        {% for match in matches %}
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <h3 class="h6 mb-0"><i class="bi bi-person-circle"></i> {{ match.other.displayName }}</h3>
                            {% if match.isMutual %}<span class="badge text-bg-success">Match mutuel</span>{% endif %}
                        </div>
                        {{ include('_reputation.html.twig', {reputation: reputations[match.other.id]}) }}
                        <div class="d-flex gap-3 my-2">
                            <span class="text-success"><i class="bi bi-arrow-up-right"></i> Je peux donner : <strong>{{ match.giveCount }}</strong></span>
                        </div>
                        <div class="d-flex gap-3 mb-2">
                            <span class="text-primary"><i class="bi bi-arrow-down-left"></i> Je peux recevoir : <strong>{{ match.receiveCount }}</strong></span>
                        </div>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="{{ path('app_trade_with', {id: match.other.id}) }}" class="btn btn-sm btn-primary w-100">Proposer un échange</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

<h2 class="h5 mb-3">Mes échanges</h2>

{% set myTotal = statusCounts|reduce((acc, c) => acc + c, 0) %}
<div class="btn-group btn-group-sm flex-wrap filter-toolbar mb-3" role="group">
    <a href="{{ path('app_trade_index') }}" class="btn {{ currentStatus is null ? 'btn-primary' : 'btn-outline-primary' }}">Tous <span class="badge text-bg-light">{{ myTotal }}</span></a>
    {% for s in statuses %}
        {% if (statusCounts[s.value] ?? 0) > 0 %}
            <a href="{{ path('app_trade_index', {status: s.value}) }}" class="btn {{ currentStatus == s ? 'btn-primary' : 'btn-outline-primary' }}">
                {{ s.label }} <span class="badge text-bg-light">{{ statusCounts[s.value] }}</span>
            </a>
        {% endif %}
    {% endfor %}
</div>

{% if myTrades is empty %}
    <p class="text-muted">{% if currentStatus %}Aucun échange dans ce statut.{% else %}Aucun échange pour l'instant. Propose un échange à un collectionneur compatible ci-dessus.{% endif %}</p>
{% else %}
    <div class="list-group mb-4">
        {% for p in myTrades %}
            {% set sent = p.fromUser.id == me.id %}
            <a href="{{ path('app_trade_show', {id: p.id}) }}" class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                    <span>
                        {% if sent %}
                            <i class="bi bi-arrow-up-right text-success" title="Envoyée"></i> À <strong>{{ p.toUser.displayName }}</strong>
                        {% else %}
                            <i class="bi bi-arrow-down-left text-primary" title="Reçue"></i> De <strong>{{ p.fromUser.displayName }}</strong>
                        {% endif %}
                        <span class="text-muted small ms-1">· donne {{ p.givenItems|length }} / reçoit {{ p.receivedItems|length }} · {{ p.updatedAt|date('d/m/Y') }}</span>
                    </span>
                    {{ include('trade/_status_badge.html.twig', {status: p.status}) }}
                </div>
            </a>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
